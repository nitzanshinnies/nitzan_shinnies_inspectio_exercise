# Copy to a local file (never commit) and apply:
#   kubectl -n inspectio create secret generic inspectio-aws \
#     --from-env-file=./secret-aws.env
#
# Real AWS: omit AWS_ENDPOINT_URL. INSPECTIO_INGEST_QUEUE_URL must be HTTPS
# to your *.fifo queue; INSPECTIO_S3_BUCKET is the journal bucket.

INSPECTIO_INGEST_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT/inspectio-ingest.fifo
INSPECTIO_S3_BUCKET=your-inspectio-journal-bucket
