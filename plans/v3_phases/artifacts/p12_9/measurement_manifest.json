{
  "namespace": "AWS/SQS",
  "measurement_method": "sum NumberOfMessagesDeleted across send shards",
  "lag_method": "max ApproximateAgeOfOldestMessage across persistence shards",
  "send_metric": {
    "name": "NumberOfMessagesDeleted",
    "stat": "Sum",
    "period_seconds": 60,
    "dimensions": [
      {
        "QueueName": "inspectio-v3-send-0"
      },
      {
        "QueueName": "inspectio-v3-send-1"
      },
      {
        "QueueName": "inspectio-v3-send-2"
      },
      {
        "QueueName": "inspectio-v3-send-3"
      },
      {
        "QueueName": "inspectio-v3-send-4"
      },
      {
        "QueueName": "inspectio-v3-send-5"
      },
      {
        "QueueName": "inspectio-v3-send-6"
      },
      {
        "QueueName": "inspectio-v3-send-7"
      }
    ]
  },
  "lag_metric": {
    "name": "ApproximateAgeOfOldestMessage",
    "stat": "Maximum",
    "period_seconds": 60,
    "dimensions": [
      {
        "QueueName": "inspectio-v3-persist-transport-0"
      },
      {
        "QueueName": "inspectio-v3-persist-transport-1"
      },
      {
        "QueueName": "inspectio-v3-persist-transport-2"
      },
      {
        "QueueName": "inspectio-v3-persist-transport-3"
      },
      {
        "QueueName": "inspectio-v3-persist-transport-4"
      },
      {
        "QueueName": "inspectio-v3-persist-transport-5"
      },
      {
        "QueueName": "inspectio-v3-persist-transport-6"
      },
      {
        "QueueName": "inspectio-v3-persist-transport-7"
      }
    ]
  },
  "preprocessing": {
    "window_preload_seconds": 60,
    "window_tail_seconds": 120,
    "repro_metric": "combined_avg_rps",
    "variance_threshold_percent": 10.0,
    "min_active_periods": 3,
    "allow_peak_gate": false
  },
  "overlap_check": {
    "overlap_detected": false,
    "overlaps": []
  },
  "run_windows": [
    {
      "run_id": "r1",
      "profile": "off",
      "job_window_utc": "2026-03-31T20:29:10Z..2026-03-31T20:33:22Z",
