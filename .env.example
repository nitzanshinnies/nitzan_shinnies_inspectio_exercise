# Copy to `.env` and adjust. Docker Compose loads `.env` from the repo root for variable substitution.
# Same names as v1 persistence (`v1_obsolete/project/src/inspectio_exercise/persistence/config.py`):
#   INSPECTIO_S3_BUCKET or S3_BUCKET, AWS_ENDPOINT_URL, AWS_REGION / AWS_DEFAULT_REGION, AWS_* credentials.

# v1-aligned default bucket name (see v1 `tests/unit/test_aws_s3_provider.py`).
INSPECTIO_S3_BUCKET=inspectio-test-bucket

# LocalStack (default): dummy keys are fine; apps use AWS_ENDPOINT_URL to reach LocalStack.
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT_URL=http://localstack:4566

# Real AWS: use the same credential source as your AWS CLI (then clear or omit AWS_ENDPOINT_URL).
# Option A — export before `docker compose up` (includes SSO / temporary creds when supported):
#   eval "$(aws configure export-credentials --format env --profile YOUR_PROFILE)"
# Option B — static keys in this file (do not commit `.env`).
# Option C — mount ~/.aws (see README); then leave AWS_ACCESS_KEY_ID unset here and use an override file.
